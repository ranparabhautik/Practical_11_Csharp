@model List<Practical_11_final.Models.User>
@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

@Html.ActionLink("Create", "Create", null, new {@class = "btn btn-success"})

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>DOB</th>
            <th>Address</th>
            <th>Edit</th>
            <th>Delete</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var x in Model)
        {
            <tr>
                <td>@x.Id</td>
                <td>@x.Name</td>
                <td>@x.DOB</td>
                <td>@x.Address</td>
                <td>@Html.ActionLink("Edit", "Edit", new { id = x.Id }, new { @class = "btn btn-primary" })</td>
                <td>@Html.ActionLink("Delete", "Delete", new { id = x.Id }, new { @class = "btn btn-danger", onclick="return confirm('are you sure you want to delete record ?');" })</td>
            </tr>
        }

    </tbody>
</table>
