@model IEnumerable<Practical_11_final.Models.User>
@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<h3>
    <a href="User/Create"> Create New</a>
</h3>

<table class="table table-striped" >
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Date of Birth</th>
            <th>Address</th>
            <th>Edit</th>
            <th>Delete</th>
            <th>View</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.DOB.ToString("yyyy-MM-dd")</td>
                <td>@item.Address</td>
                <td>    <a href="/User/Edit/@item.Id">Edit</a></td>
                <td>
                    <a href="/User/Delete/@item.Id"
                       onclick="return confirm('Are you sure you want to delete this user?');">
                        Delete
                    </a>
                </td>
                <td>
                    <a href="/User/Details/@item.Id">View</a>
                </td>
            </tr>
        }
    </tbody>
</table>